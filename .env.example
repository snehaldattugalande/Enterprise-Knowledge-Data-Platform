# Example environment variables for the enterprise knowledge data platform
# Rename to .env and set your own credentials for local development.

SHAREPOINT_TENANT_ID=YOUR_SHAREPOINT_TENANT_ID
SHAREPOINT_CLIENT_ID=YOUR_SHAREPOINT_CLIENT_ID
SHAREPOINT_CLIENT_SECRET=YOUR_SHAREPOINT_CLIENT_SECRET
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/EnterpriseDocuments
SHAREPOINT_LIBRARY_NAME="Shared Documents"

SNOWFLAKE_ACCOUNT=YOUR_SNOWFLAKE_ACCOUNT
SNOWFLAKE_USER=YOUR_SNOWFLAKE_USER
SNOWFLAKE_PASSWORD=YOUR_SNOWFLAKE_PASSWORD
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ENTERPRISE_DB
SNOWFLAKE_SCHEMA=DOCUMENTS
SNOWFLAKE_ROLE=SYSADMIN

OPENSEARCH_HOST=https://search-your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX_NAME=enterprise-documents
